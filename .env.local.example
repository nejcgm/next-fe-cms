# Environment Configuration
NODE_ENV=development

# Required for on-demand revalidation webhook
REVALIDATE_SECRET=your-secret-here-min-16-chars

# Strapi CMS (enable when ready to switch from mock)
# STRAPI_URL=http://localhost:1337
# STRAPI_API_TOKEN=your-strapi-api-token

# Preview mode secret
# PREVIEW_SECRET=your-preview-secret

# Resort Example Tenant - Booking Integration
# RESORT_BOOKING_API_URL=https://api.booking-provider.com
# RESORT_BOOKING_API_KEY=your-api-key
